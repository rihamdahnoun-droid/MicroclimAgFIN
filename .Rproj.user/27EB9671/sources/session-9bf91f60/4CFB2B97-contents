#' Import Weather Station Locations
#'
#' @description
#' Imports weather station locations from a CSV file with GPS coordinates
#' or a shapefile, and converts them to a spatial sf object.
#'
#' @param file_path Character. Path to CSV file or shapefile (.shp).
#' @param lon_col Character. Name of longitude column. Default is "longitude".
#' @param lat_col Character. Name of latitude column. Default is "latitude".
#' @param id_col Character. Name of station ID column. Default is "station_id".
#' @param name_col Character. Name of station name column. Default is "name".
#' @param crs Numeric. EPSG code for coordinate system. Default is 4326 (WGS84).
#' @param plot_map Logical. Whether to display a map of stations. Default is TRUE.
#'
#' @return An sf object containing station locations with columns:
#' \describe{
#'   \item{station_id}{Station identifier}
#'   \item{name}{Station name}
#'   \item{longitude}{Longitude in decimal degrees}
#'   \item{latitude}{Latitude in decimal degrees}
#'   \item{geometry}{Point geometry (sf)}
#' }
#'
#' @examples
#' \dontrun{
#' # From CSV
#' stations <- import_station_locations("data/stations.csv")
#'
#' # From shapefile
#' stations <- import_station_locations("data/stations.shp")
#'
#' # Custom column names
#' stations <- import_station_locations(
#'   file_path = "data/stations.csv",
#'   lon_col   = "lon",
#'   lat_col   = "lat",
#'   id_col    = "id"
#' )
#' }
#'
#' @importFrom sf st_as_sf st_crs st_transform read_sf
#' @importFrom ggplot2 ggplot aes geom_sf geom_sf_text theme_minimal labs
#' @export
import_station_locations <- function(file_path,
                                     lon_col  = "longitude",
                                     lat_col  = "latitude",
                                     id_col   = "station_id",
                                     name_col = "name",
                                     crs      = 4326,
                                     plot_map = TRUE) {

  # --- 1. Vérifier que le fichier existe ---
  if (!file.exists(file_path)) {
    stop("File not found: ", file_path)
  }

  ext <- tolower(tools::file_ext(file_path))

  # --- 2. Lire le fichier selon le format ---
  if (ext == "csv") {

    df <- read.csv(file_path, stringsAsFactors = FALSE)

    # Vérifier colonnes longitude/latitude
    missing_cols <- c(lon_col, lat_col)[!c(lon_col, lat_col) %in% names(df)]
    if (length(missing_cols) > 0) {
      stop("Missing columns: ", paste(missing_cols, collapse = ", "),
           "\nAvailable columns: ", paste(names(df), collapse = ", "))
    }

    # Convertir en objet sf
    stations_sf <- sf::st_as_sf(
      df,
      coords = c(lon_col, lat_col),
      crs    = crs
    )

    # Ajouter colonnes longitude/latitude explicites
    stations_sf$longitude <- df[[lon_col]]
    stations_sf$latitude  <- df[[lat_col]]

  } else if (ext == "shp") {

    stations_sf <- sf::read_sf(file_path)

    # Vérifier/corriger le CRS
    if (is.na(sf::st_crs(stations_sf))) {
      message("No CRS found in shapefile. Assigning EPSG:", crs)
      sf::st_crs(stations_sf) <- crs
    }

    # Reprojeter si nécessaire
    if (sf::st_crs(stations_sf)$epsg != crs) {
      message("Reprojecting to EPSG:", crs)
      stations_sf <- sf::st_transform(stations_sf, crs = crs)
    }

  } else {
    stop("Unsupported format. Please use CSV or shapefile (.shp).")
  }

  # --- 3. Standardiser les colonnes ---
  if (id_col %in% names(stations_sf)) {
    stations_sf$station_id <- stations_sf[[id_col]]
  } else {
    stations_sf$station_id <- paste0("S", seq_len(nrow(stations_sf)))
    message("Column '", id_col, "' not found. Auto-generated IDs.")
  }

  if (name_col %in% names(stations_sf)) {
    stations_sf$name <- stations_sf[[name_col]]
  } else {
    stations_sf$name <- stations_sf$station_id
    message("Column '", name_col, "' not found. Using station_id as name.")
  }

  # --- 4. Afficher la carte ---
  if (plot_map) {
    p <- ggplot2::ggplot(data = stations_sf) +
      ggplot2::geom_sf(color = "red", size = 3, shape = 17) +
      ggplot2::geom_sf_text(
        ggplot2::aes(label = name),
        nudge_y = 0.05,
        size    = 3
      ) +
      ggplot2::theme_minimal() +
      ggplot2::labs(
        title    = "Weather Station Locations",
        subtitle = paste(nrow(stations_sf), "stations"),
        x        = "Longitude",
        y        = "Latitude"
      )
    print(p)
  }

  # --- 5. Résumé ---
  message("Station locations imported successfully.")
  message("  Number of stations : ", nrow(stations_sf))
  message("  CRS                : EPSG ", crs)
  message("  Stations           : ", paste(stations_sf$name, collapse = ", "))

  return(stations_sf)
}
