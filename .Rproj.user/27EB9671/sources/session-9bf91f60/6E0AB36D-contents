#' Generate Microclimate Analysis Report
#'
#' @description
#' Generates an automatic HTML or PDF report summarizing all microclimate
#' analysis results including LST statistics, thermal anomalies, NDVI
#' comparison, spatial clusters, and model performance.
#'
#' @param lst SpatRaster. Cleaned LST raster. Default is NULL.
#' @param ndvi SpatRaster. NDVI raster. Default is NULL.
#' @param anomalies List. Output from calculate_lst_anomaly(). Default is NULL.
#' @param thermal_zones List. Output from cluster_thermal_zones(). Default is NULL.
#' @param model_results List. Output from model_temperature_relationships(). Default is NULL.
#' @param spatial_corr List. Output from analyze_spatial_correlation(). Default is NULL.
#' @param lst_ndvi List. Output from compare_lst_vs_ndvi(). Default is NULL.
#' @param features Data frame. Output from extract_microclimate_features(). Default is NULL.
#' @param country Character. Country name for the report. Default is "Morocco".
#' @param region Character. Region name for the report. Default is "Study Area".
#' @param format Character. Output format: "html" or "pdf". Default is "html".
#' @param output_dir Character. Directory to save report. Default is "outputs/reports".
#' @param open_report Logical. Whether to open the report after generation. Default is TRUE.
#'
#' @return Invisibly returns the path to the generated report.
#'
#' @examples
#' \dontrun{
#' generate_report(
#'   lst           = lst_clean,
#'   ndvi          = ndvi,
#'   anomalies     = anomalies,
#'   thermal_zones = thermal_zones,
#'   model_results = model_results,
#'   country       = "Morocco",
#'   region        = "Tanger-Tetouan",
#'   format        = "html"
#' )
#' }
#'
#' @importFrom terra values nlyr global
#' @importFrom rmarkdown render
#' @importFrom ggplot2 ggplot aes geom_raster geom_bar geom_point
#'             scale_fill_gradientn theme_minimal labs geom_abline
#'             geom_smooth scale_fill_manual geom_hline coord_flip
#'             scale_fill_gradient2 geom_boxplot
#' @importFrom grDevices heat.colors colorRampPalette
#' @export
generate_report <- function(lst           = NULL,
                            ndvi          = NULL,
                            anomalies     = NULL,
                            thermal_zones = NULL,
                            model_results = NULL,
                            spatial_corr  = NULL,
                            lst_ndvi      = NULL,
                            features      = NULL,
                            country       = "Morocco",
                            region        = "Study Area",
                            format        = "html",
                            output_dir    = "outputs/reports",
                            open_report   = TRUE) {

  # ============================================================
  # BLOC 1 — Vérifications
  # ============================================================

  if (!format %in% c("html", "pdf")) {
    stop("format must be 'html' or 'pdf'.")
  }

  message("========================================")
  message("  microclimAg — Report Generation      ")
  message("========================================\n")
  message("Format  : ", toupper(format))
  message("Country : ", country)
  message("Region  : ", region)

  if (!dir.exists(output_dir)) dir.create(output_dir, recursive = TRUE)

  # ============================================================
  # BLOC 2 — Créer le template Rmarkdown
  # ============================================================

  message("\nCreating report template...")

  report_date <- format(Sys.Date(), "%B %d, %Y")
  rmd_file    <- file.path(output_dir, "microclimate_report.Rmd")

  rmd_content <- paste0(
    '---
title: "Microclimate Analysis Report"
subtitle: "', region, ' — ', country, '"
date: "', report_date, '"
output:
  ', ifelse(format == "html", "html_document", "pdf_document"), ':
    toc: true
    toc_depth: 3
    number_sections: true
    ', ifelse(format == "html",
              'theme: flatly\n    highlight: tango',
              'latex_engine: xelatex'), '
---

```{r setup, include=FALSE}
knitr::opts_chunk$set(
  echo    = FALSE,
  warning = FALSE,
  message = FALSE,
  fig.width  = 8,
  fig.height = 5,
  dpi = 120
)
library(ggplot2)
library(terra)
```

# Executive Summary

This report presents the results of a microclimate analysis conducted for
**', region, '**, **', country, '**, generated on ', report_date, '
using the **microclimAg** R package.

The analysis integrates:

- Land Surface Temperature (LST) from WorldClim + Open-Meteo
- Normalized Difference Vegetation Index (NDVI)
- Elevation data (SRTM 30s)
- Spatial clustering and statistical modelling

