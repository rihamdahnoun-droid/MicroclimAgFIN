```{r model-plot, fig.cap="Observed vs Predicted LST"}
if (!is.null(model_results_obj)) {
  pd <- model_results_obj$predictions
  r2 <- model_results_obj$metrics$value[
    model_results_obj$metrics$metric == "R_squared"]

  ggplot(pd, aes(x = observed, y = predicted)) +
    geom_point(alpha = 0.3, color = "steelblue", size = 0.8) +
    geom_abline(slope = 1, intercept = 0,
                color = "red", linetype = "dashed") +
    geom_smooth(method = "lm", se = TRUE, color = "black") +
    theme_minimal() +
    labs(
      title    = "Observed vs Predicted LST",
      subtitle = paste("R² =", r2),
      x = "Observed LST (C)", y = "Predicted LST (C)"
    )
}
```

