# 2. Land Surface Temperature (LST)

```{r lst-stats}
if (!is.null(lst_obj)) {
  lst_vals <- terra::values(lst_obj)
  lst_vals <- lst_vals[!is.na(lst_vals)]

  cat("LST Statistics:\n")
  cat("  Layers     :", terra::nlyr(lst_obj), "\n")
  cat("  Mean LST   :", round(mean(lst_vals), 2), "C\n")
  cat("  Min LST    :", round(min(lst_vals),  2), "C\n")
  cat("  Max LST    :", round(max(lst_vals),  2), "C\n")
  cat("  SD LST     :", round(sd(lst_vals),   2), "C\n")
}
```

```{r lst-map, fig.cap="Land Surface Temperature Map"}
if (!is.null(lst_obj)) {
  df <- as.data.frame(lst_obj[[1]], xy = TRUE)
  names(df) <- c("x", "y", "lst")
  df <- df[!is.na(df$lst), ]

  ggplot(df, aes(x = x, y = y, fill = lst)) +
    geom_raster() +
    scale_fill_gradientn(
      colors = rev(heat.colors(100)),
      name   = "LST (C)"
    ) +
    theme_minimal() +
    labs(
      title = "Land Surface Temperature",
      x = "Longitude", y = "Latitude"
    )
}
```

