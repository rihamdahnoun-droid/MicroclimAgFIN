')

writeLines(rmd_content, rmd_file)
message("  Template created: ", rmd_file)

# ============================================================
# BLOC 3 — Préparer l'environnement pour le rapport
# ============================================================

message("\nPreparing report environment...")

report_env <- new.env()

report_env$lst_obj           <- lst
report_env$ndvi_obj          <- ndvi
report_env$anomalies_obj     <- anomalies
report_env$thermal_zones_obj <- thermal_zones
report_env$model_results_obj <- model_results
report_env$spatial_corr_obj  <- spatial_corr
report_env$lst_ndvi_obj      <- lst_ndvi
report_env$features_obj      <- features

# ============================================================
# BLOC 4 — Générer le rapport
# ============================================================

message("Rendering report (this may take a minute)...")

out_file <- file.path(
  output_dir,
  paste0("microclimate_report_",
         gsub(" ", "_", region), ".",
         format)
)

tryCatch({
  rmarkdown::render(
    input       = rmd_file,
    output_file = out_file,
    envir       = report_env,
    quiet       = TRUE
  )
  message("  Report saved to: ", out_file)
}, error = function(e) {
  message("  Error rendering report: ", e$message)
  message("  Try installing: install.packages('rmarkdown')")
})

# ============================================================
# BLOC 5 — Ouvrir le rapport
# ============================================================

if (open_report && file.exists(out_file)) {
  message("\nOpening report in browser...")
  utils::browseURL(out_file)
}

# ============================================================
# BLOC 6 — Résumé final
# ============================================================

message("\n========================================")
message("       Report Generation Complete!")
message("========================================")
message("  Format  : ", toupper(format))
message("  Region  : ", region)
message("  Country : ", country)
message("  File    : ", out_file)
message("========================================")

invisible(out_file)
}
