# 3. Vegetation Index (NDVI)

```{r ndvi-stats}
if (!is.null(ndvi_obj)) {
  ndvi_vals <- terra::values(ndvi_obj)
  ndvi_vals <- ndvi_vals[!is.na(ndvi_vals)]

  cat("NDVI Statistics:\n")
  cat("  Mean NDVI  :", round(mean(ndvi_vals), 3), "\n")
  cat("  Min NDVI   :", round(min(ndvi_vals),  3), "\n")
  cat("  Max NDVI   :", round(max(ndvi_vals),  3), "\n")
  cat("  Veg cover  :", round(100 * mean(ndvi_vals > 0.3), 1), "%\n")
}
```

```{r ndvi-map, fig.cap="NDVI Map"}
if (!is.null(ndvi_obj)) {
  df <- as.data.frame(ndvi_obj[[1]], xy = TRUE)
  names(df) <- c("x", "y", "ndvi")
  df <- df[!is.na(df$ndvi), ]

  ndvi_colors <- colorRampPalette(c(
    "#8B4513", "#D2B48C", "#FFFF00",
    "#90EE90", "#228B22", "#006400"
  ))(100)

  ggplot(df, aes(x = x, y = y, fill = ndvi)) +
    geom_raster() +
    scale_fill_gradientn(
      colors = ndvi_colors,
      limits = c(-1, 1),
      name   = "NDVI"
    ) +
    theme_minimal() +
    labs(
      title = "Normalized Difference Vegetation Index",
      x = "Longitude", y = "Latitude"
    )
}
