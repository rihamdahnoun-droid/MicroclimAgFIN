```{r ndvi-map, fig.cap="NDVI Map"}
if (!is.null(ndvi_obj)) {
  df <- as.data.frame(ndvi_obj[[1]], xy = TRUE)
  names(df) <- c("x", "y", "ndvi")
  df <- df[!is.na(df$ndvi), ]

  ndvi_colors <- colorRampPalette(c(
    "#8B4513", "#D2B48C", "#FFFF00",
    "#90EE90", "#228B22", "#006400"
