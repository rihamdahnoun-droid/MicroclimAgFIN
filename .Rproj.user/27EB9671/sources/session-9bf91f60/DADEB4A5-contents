# 5. Thermal Zone Classification

```{r thermal-stats}
if (!is.null(thermal_zones_obj)) {
  cat("Thermal Zone Statistics:
")
  print(thermal_zones_obj$stats)
}
```

```{r thermal-map, fig.cap="Thermal Zone Map"}
if (!is.null(thermal_zones_obj)) {
  df <- as.data.frame(thermal_zones_obj$raster, xy = TRUE)
  names(df) <- c("x", "y", "zone")
  df <- df[!is.na(df$zone), ]

  zone_labels <- c("1"="Cool","2"="Moderate","3"="Warm","4"="Hot")
  df$zone_label <- factor(
    zone_labels[as.character(round(df$zone))],
    levels = c("Cool","Moderate","Warm","Hot")
  )

  ggplot(df, aes(x = x, y = y, fill = zone_label)) +
    geom_raster() +
    scale_fill_manual(
      values = c("Cool"="#4575B4","Moderate"="#91BFDB",
                 "Warm"="#FC8D59","Hot"="#D73027"),
      name = "Zone", na.value = "white"
    ) +
    theme_minimal() +
    labs(title = "Thermal Zone Classification",
         x = "Longitude", y = "Latitude")
}
```

