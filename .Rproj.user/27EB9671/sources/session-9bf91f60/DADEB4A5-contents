    geom_raster() +
    scale_fill_gradientn(
      colors = ndvi_colors,
      limits = c(-1, 1),
      name   = "NDVI"
    ) +
    theme_minimal() +
    labs(
      title = "Normalized Difference Vegetation Index",
      x = "Longitude", y = "Latitude"
    )
}
```

