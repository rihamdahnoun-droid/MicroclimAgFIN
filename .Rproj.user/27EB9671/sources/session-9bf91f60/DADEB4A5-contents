# 6. LST vs NDVI Relationship

```{r lst-ndvi}
if (!is.null(lst_ndvi_obj)) {
  cat("Overall LST-NDVI Correlation:
")
  cat("  Pearson r :", lst_ndvi_obj$correlation$r, "
")
  cat("  p-value   :", lst_ndvi_obj$correlation$p, "
")

  if (!is.null(lst_ndvi_obj$scatter_data)) {
    sd <- lst_ndvi_obj$scatter_data
    ggplot(sd, aes(x = ndvi_mean, y = lst_mean)) +
      geom_point(aes(color = lst_mean), alpha = 0.3, size = 0.8) +
      scale_color_gradientn(
        colors = rev(heat.colors(100)), name = "LST (C)"
      ) +
      geom_smooth(method = "lm", se = TRUE, color = "black") +
      theme_minimal() +
      labs(
        title    = "LST vs NDVI",
        subtitle = paste("r =", lst_ndvi_obj$correlation$r),
        x = "NDVI", y = "LST (C)"
      )
  }
}
```

