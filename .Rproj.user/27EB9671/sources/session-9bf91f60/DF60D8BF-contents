# Methods

## Data Sources

| Variable | Source |
|----------|--------|
| LST | WorldClim v2.1 + Open-Meteo archive API |
| NDVI | Open-Meteo ET0/Precipitation proxy + elevation variation |
| Land Cover | ESA Land Cover (geodata package) |
| Elevation | SRTM 30 arc-second (geodata package) |
| Weather | User-provided CSV/Excel |

## Software

- **R** statistical environment
- **terra**: raster analysis
- **sf**: vector spatial data
- **spdep**: spatial autocorrelation (Moran\'s I, LISA)
- **gstat**: interpolation (IDW, kriging)
- **geodata**: data download
- **ggplot2**: visualization

---

# Outputs

All outputs are saved to the `outputs/` directory:

| Folder | Content |
|--------|---------|
| `outputs/maps/` | Raster files (.tif): LST, NDVI, anomalies, clusters |
| `outputs/tables/` | CSV tables: statistics, correlations, model results |
| `outputs/reports/` | This report |

---

*Report generated by microclimAg — %s*
',
                         study_area, period, author, gen_date,
                         # Executive summary stats
                         lst_stats$mean, lst_stats$min, lst_stats$max,
                         lst_stats$sd,
                         ifelse(!is.null(ndvi_stats),
                                paste0("- Mean NDVI: **", ndvi_stats$mean, "**"), ""),
                         lst_stats$n_layers,
                         # Study area table
                         ifelse(country != "", country, "—"),
                         ifelse(region  != "", region,  "—"),
                         ifelse(period  != "", period,  "—"),
                         lst_stats$n_layers,
                         # LST stats table
                         lst_stats$mean, lst_stats$sd,
                         lst_stats$min,  lst_stats$max,
                         lst_stats$q25,  lst_stats$q75,
                         # Figure LST
                         fig_paths[["lst_mean"]],
                         # Sections conditionnelles
                         ndvi_section, anomaly_section, cluster_section,
                         model_section, corr_section, autocorr_section,
                         weather_section,
                         # Footer
                         format(Sys.time(), "%Y-%m-%d %H:%M:%S")
  )

  # ============================================================
  # BLOC 5 — Sauvegarder et rendre le Rmd
  # ============================================================

  rmd_path <- file.path(output_dir, "microclimate_report.Rmd")
  writeLines(rmd_content, rmd_path)
  message("  Rmd template written: ", rmd_path)

  output_files <- character(0)
  formats_to_render <- if (output_format == "both") c("html", "pdf") else output_format

  for (fmt in formats_to_render) {
    out_file <- file.path(output_dir,
                          paste0("microclimate_report.", fmt))

    rmd_format <- if (fmt == "html") "html_document" else "pdf_document"

    message("\nRendering ", toupper(fmt), " report...")

    tryCatch({
      rmarkdown::render(
        input         = rmd_path,
        output_format = rmd_format,
        output_file   = basename(out_file),
        output_dir    = output_dir,
        quiet         = TRUE
      )
      output_files <- c(output_files, out_file)
      message("  Report generated: ", out_file)

      if (open_report && fmt == "html" && interactive()) {
        utils::browseURL(out_file)
      }

    }, error = function(e) {
      message("  Error rendering ", fmt, ": ", e$message)
      message("  The Rmd source is available at: ", rmd_path)
    })
  }

  # ============================================================
  # BLOC 6 — Résumé final
  # ============================================================

  message("\n========================================")
  message("    Report Generation Complete!")
  message("========================================")
  message("  Study area : ", study_area)
  message("  Period     : ", ifelse(period != "", period, "—"))
  message("  LST mean   : ", lst_stats$mean, " °C")
  for (f in output_files) message("  Output     : ", f)
  message("========================================")

  invisible(output_files)
}
