#' Import Weather Data
#'
#' @description
#' Imports meteorological data from CSV or Excel files containing
#' temperature, humidity, wind speed, and radiation measurements
#' from one or multiple weather stations.
#'
#' @param file_path Character. Path to the CSV or Excel file.
#' @param date_col Character. Name of the date column. Default is "date".
#' @param temp_col Character. Name of the temperature column. Default is "temperature".
#' @param humidity_col Character. Name of the humidity column. Default is "humidity".
#' @param wind_col Character. Name of the wind speed column. Default is "wind_speed".
#' @param radiation_col Character. Name of the radiation column. Default is "radiation".
#' @param station_col Character. Name of the station ID column. Default is "station_id".
#' @param date_format Character. Format of the date column. Default is "%Y-%m-%d".
#'
#' @return A data frame with standardized weather variables:
#' \describe{
#'   \item{date}{Date column (Date format)}
#'   \item{station_id}{Station identifier}
#'   \item{temperature}{Air temperature in degrees Celsius}
#'   \item{humidity}{Relative humidity in percent}
#'   \item{wind_speed}{Wind speed in m/s}
#'   \item{radiation}{Solar radiation in W/m2}
#' }
#'
#' @examples
#' \dontrun{
#' # CSV file
#' weather <- import_weather_data("data/weather.csv")
#'
#' # Excel file with custom column names
#' weather <- import_weather_data(
#'   file_path     = "data/weather.xlsx",
#'   date_col      = "Date",
#'   temp_col      = "Temp_C",
#'   humidity_col  = "RH",
#'   wind_col      = "Wind",
#'   radiation_col = "Rad"
#' )
#' }
#'
#' @importFrom utils read.csv
#' @export
import_weather_data <- function(file_path,
                                date_col      = "date",
                                temp_col      = "temperature",
                                humidity_col  = "humidity",
                                wind_col      = "wind_speed",
                                radiation_col = "radiation",
                                station_col   = "station_id",
                                date_format   = "%Y-%m-%d") {

  # --- 1. Vérifier que le fichier existe ---
  if (!file.exists(file_path)) {
    stop("File not found: ", file_path)
  }

  # --- 2. Détecter le format et lire le fichier ---
  ext <- tolower(tools::file_ext(file_path))

  if (ext == "csv") {
    df <- read.csv(file_path, stringsAsFactors = FALSE)

  } else if (ext %in% c("xlsx", "xls")) {
    if (!requireNamespace("readxl", quietly = TRUE)) {
      stop("Package 'readxl' is required for Excel files. Install it with: install.packages('readxl')")
    }
    df <- readxl::read_excel(file_path)
    df <- as.data.frame(df)

  } else {
    stop("Unsupported file format. Please use CSV or Excel (.xlsx, .xls).")
  }

  # --- 3. Vérifier les colonnes obligatoires ---
  required_cols <- c(date_col, temp_col)
  missing_cols  <- required_cols[!required_cols %in% names(df)]

  if (length(missing_cols) > 0) {
    stop("Missing required columns: ", paste(missing_cols, collapse = ", "),
         "\nAvailable columns: ", paste(names(df), collapse = ", "))
  }

  # --- 4. Standardiser les noms de colonnes ---
  result <- data.frame(
    date        = as.Date(df[[date_col]], format = date_format),
    temperature = as.numeric(df[[temp_col]])
  )

  # Colonnes optionnelles
  if (humidity_col %in% names(df)) {
    result$humidity <- as.numeric(df[[humidity_col]])
  } else {
    result$humidity <- NA_real_
    message("Column '", humidity_col, "' not found. Set to NA.")
  }

  if (wind_col %in% names(df)) {
    result$wind_speed <- as.numeric(df[[wind_col]])
  } else {
    result$wind_speed <- NA_real_
    message("Column '", wind_col, "' not found. Set to NA.")
  }

  if (radiation_col %in% names(df)) {
    result$radiation <- as.numeric(df[[radiation_col]])
  } else {
    result$radiation <- NA_real_
    message("Column '", radiation_col, "' not found. Set to NA.")
  }

  if (station_col %in% names(df)) {
    result$station_id <- df[[station_col]]
  } else {
    result$station_id <- "station_1"
    message("Column '", station_col, "' not found. Using 'station_1' as default.")
  }

  # --- 5. Gestion des données manquantes ---
  n_na_date <- sum(is.na(result$date))
  n_na_temp <- sum(is.na(result$temperature))

  if (n_na_date > 0) {
    warning(n_na_date, " rows have invalid dates and will be removed.")
    result <- result[!is.na(result$date), ]
  }

  if (n_na_temp > 0) {
    message(n_na_temp, " missing temperature values (NA) kept in dataset.")
  }

  # --- 6. Trier par date ---
  result <- result[order(result$date), ]
  rownames(result) <- NULL

  # --- 7. Résumé ---
  message("Weather data imported successfully.")
  message("  Stations : ", paste(unique(result$station_id), collapse = ", "))
  message("  Period   : ", min(result$date), " to ", max(result$date))
  message("  Rows     : ", nrow(result))

  return(result)
}
